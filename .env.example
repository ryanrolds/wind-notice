PORT=5000
REFRESH_INTERVAL_HOURS=6

# Timezone for all cron schedules
TIMEZONE=America/Los_Angeles

# Email schedule
EMAIL_ENABLED=false
EMAIL_CRON=0 9 * * *
EMAIL_FROM=Wind Notice <no-reply@pedanticorderliness.com>
EMAIL_TO=recipient@example.com

# Afternoon sailing alert email (sends when today's score meets threshold)
ALERT_ENABLED=false
ALERT_CRON=0 11 * * *
ALERT_MIN_SCORE=65

# AWS configuration (used by SES email)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
